{
	"name": "kahraman",
	"version": "0.1.1",
	"description": "Accessibility-first, codecept-style test actor and locator DSL for Storybook portable stories and Vitest browser mode.",
	"keywords": [
		"storybook-addon",
		"test",
		"storybook",
		"testing",
		"actor",
		"testing-library",
		"a11y",
		"accessibility",
		"e2e",
		"codeceptjs",
		"vitest",
		"locator"
	],
	"storybook": {
		"displayName": "kahraman",
		"supportedFrameworks": [
			"react",
			"vue",
			"svelte",
			"preact",
			"web-components",
			"html"
		]
	},
	"homepage": "https://apphane.dev/",
	"bugs": {
		"url": "https://github.com/apphane-dev/kahraman/issues"
	},
	"license": "MIT",
	"author": "Aleksei Gurianov",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/apphane-dev/kahraman.git"
	},
	"files": [
		"dist",
		"src",
		"README.md",
		"LICENSE"
	],
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./preview": {
			"types": "./dist/preview.d.ts",
			"default": "./dist/preview.js"
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": "tsdown",
		"typecheck": "tsc --noEmit",
		"lint": "vp lint",
		"lint:fallow": "fallow dead-code --fail-on-issues && fallow dupes --fail-on-issues && fallow health --complexity --fail-on-issues",
		"format": "vp fmt --check",
		"format:fix": "vp fmt",
		"test": "vp test run",
		"test:watch": "vp test",
		"check": "pnpm run typecheck && pnpm run lint && pnpm run lint:fallow && pnpm run format && pnpm run test",
		"attw": "attw --pack . --profile esm-only",
		"registry:build": "jsrepo build",
		"publint": "publint",
		"prepack": "tsdown",
		"release": "changeset publish"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.5",
		"@changesets/cli": "^2.31.0",
		"fallow": "^3.5.1",
		"jsrepo": "^3.8.1",
		"publint": "^0.3.21",
		"storybook": "^10.5.0",
		"tsdown": "^0.22.7",
		"typescript": "^7.0.2",
		"vite-plus": "^0.2.4",
		"vitest": "4.1.10"
	},
	"peerDependencies": {
		"storybook": ">=9.0.0"
	},
	"engines": {
		"node": ">=20.11.0"
	},
	"packageManager": "pnpm@11.13.0"
}
